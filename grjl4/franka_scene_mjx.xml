<!--
  grjl4 — 夏虫运冰 (Block Stacking) — MJX variant

  MJX-compatible variant for GPU-batched training via JAX.
  Key differences from franka_scene.xml:
    - integrator: implicitfast (MJX requirement)
    - Franka: mjx_panda.xml (box collision primitives)

  Block types (K_type = 1..4):
    1. 正方体 (cube)    — box 4×4×4 cm
    2. 长方体 (cuboid)  — box 4×4×4 cm
    3. 卯 (mortise)     — mesh: cuboid with V-notch at bottom
    4. 榫 (tenon)       — mesh: cuboid with triangle tab on top
    Constraint: mesh(3) + mesh(4) = cuboid (complementary 榫卯 pair)

  Wind: applied at runtime via mjx data.xfrc_applied.
-->
<mujoco model="grjl4_block_stacking_mjx">

  <!-- ── Compiler ─────────────────────────────────────── -->
  <compiler angle="radian" autolimits="true" meshdir="assets"/>

  <!-- ── Options ──────────────────────────────────────── -->
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"
          cone="elliptic" impratio="10">
    <flag contact="enable"/>
  </option>

  <size nconmax="200" njmax="500"/>

  <!-- ── Defaults ─────────────────────────────────────── -->
  <default>
    <default class="block">
      <geom condim="4" friction="0.8 0.005 0.0001" density="625"
            solref="0.004 0.8" solimp="0.95 0.99 0.001"/>
    </default>
  </default>

  <!-- ── Include MJX-compatible Franka Panda ─────────── -->
  <include file="mujoco_menagerie/franka_emika_panda/mjx_panda.xml"/>

  <!-- ── Assets ───────────────────────────────────────── -->
  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7"
             rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker"
             mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane"
              texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="block_cube"     rgba="0.9 0.2 0.2 1"/>
    <material name="block_cuboid"   rgba="0.2 0.7 0.2 1"/>
    <material name="block_mortise"  rgba="0.2 0.3 0.9 1"/>
    <material name="block_tenon"    rgba="0.9 0.6 0.1 1"/>

    <!-- Meshes for types 3-4 (榫卯 pair, generated by generate_meshes.py) -->
    <mesh name="mortise_L" file="mortise_L.stl"/>
    <mesh name="mortise_R" file="mortise_R.stl"/>
    <mesh name="tenon"     file="tenon.stl"/>
  </asset>

  <!-- ── World ────────────────────────────────────────── -->
  <worldbody>
    <light pos="0 0 2.0" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane"
          material="groundplane"/>

    <!-- ── Cameras ───────────────────────────────── -->
    <camera name="overhead" pos="0.45 0 1.0" xyaxes="1 0 0 0 1 0"/>
    <camera name="side" pos="0.9 0 0.3" xyaxes="0 1 0 0 0 1"/>

    <!-- ── Blocks (on ground, z = half-height) ──── -->
    <!-- ── Blocks (diagonal placement, no mutual occlusion) ── -->
    <!-- Type 1: 正方体 (cube) 4×4×4 cm — red -->
    <body name="block_cube_0" pos="0.42 -0.08 0.02">
      <freejoint name="block_cube_0_joint"/>
      <geom name="block_cube_0_geom" class="block" type="box"
            size="0.02 0.02 0.02" material="block_cube" mass="0.1"/>
    </body>

    <!-- Type 2: 长方体 (cuboid) 4×4×8 cm — green -->
    <body name="block_cuboid_0" pos="0.48 -0.03 0.04">
      <freejoint name="block_cuboid_0_joint"/>
      <geom name="block_cuboid_0_geom" class="block" type="box"
            size="0.02 0.02 0.04" material="block_cuboid" mass="0.2"/>
    </body>

    <!-- Type 3: 卯 (mortise) — blue, 4cm tall with V-notch
         Two convex halves to preserve concave notch in collision. -->
    <body name="block_mortise_0" pos="0.54 0.03 0.02">
      <freejoint name="block_mortise_0_joint"/>
      <geom name="block_mortise_0_L" class="block" type="mesh"
            mesh="mortise_L" material="block_mortise" mass="0.044"/>
      <geom name="block_mortise_0_R" class="block" type="mesh"
            mesh="mortise_R" material="block_mortise" mass="0.044"/>
    </body>

    <!-- Type 4: 榫 (tenon) — orange, 4cm base + 1cm tab -->
    <body name="block_tenon_0" pos="0.60 0.08 0.02">
      <freejoint name="block_tenon_0_joint"/>
      <geom name="block_tenon_0_geom" class="block" type="mesh"
            mesh="tenon" material="block_tenon" mass="0.113"/>
    </body>

  </worldbody>

  <!-- ── Sensors ─────────────────────────────────────── -->
  <sensor>
    <jointpos name="joint1_pos" joint="joint1"/>
    <jointpos name="joint2_pos" joint="joint2"/>
    <jointpos name="joint3_pos" joint="joint3"/>
    <jointpos name="joint4_pos" joint="joint4"/>
    <jointpos name="joint5_pos" joint="joint5"/>
    <jointpos name="joint6_pos" joint="joint6"/>
    <jointpos name="joint7_pos" joint="joint7"/>
    <jointvel name="joint1_vel" joint="joint1"/>
    <jointvel name="joint2_vel" joint="joint2"/>
    <jointvel name="joint3_vel" joint="joint3"/>
    <jointvel name="joint4_vel" joint="joint4"/>
    <jointvel name="joint5_vel" joint="joint5"/>
    <jointvel name="joint6_vel" joint="joint6"/>
    <jointvel name="joint7_vel" joint="joint7"/>
  </sensor>

  <!-- ── Keyframes ────────────────────────────────────── -->
  <keyframe>
    <key name="ready"
         qpos="0 0.3 0 -1.5708 0 2.0 -0.7854 0.04 0.04
               0.42 -0.08 0.02 1 0 0 0
               0.48 -0.03 0.04 1 0 0 0
               0.54  0.03 0.02 1 0 0 0
               0.60  0.08 0.02 1 0 0 0"
         ctrl="0 0.3 0 -1.5708 0 2.0 -0.7854 255"/>
  </keyframe>

</mujoco>
